{
  "name": "portafolio-v3",
  "version": "3.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "deploy-github": "ng build --base-href /robinlugoboero/ && mv dist/Portafolio-v3/browser/index.csr.html dist/Portafolio-v3/browser/index.html && npx angular-cli-ghpages --dir=dist/Portafolio-v3/browser",
    "lint": "ng lint",
    "serve:ssr:Portafolio-v3": "node dist/Portafolio-v3/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.10.0",
  "dependencies": {
    "@angular/common": "^21.1.4",
    "@angular/compiler": "^21.1.4",
    "@angular/core": "^21.1.4",
    "@angular/forms": "^21.1.4",
    "@angular/platform-browser": "^21.1.4",
    "@angular/platform-server": "^21.1.4",
    "@angular/router": "^21.1.4",
    "@angular/service-worker": "^21.1.4",
    "@angular/ssr": "^21.1.4",
    "@fortawesome/angular-fontawesome": "^4.0.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@vercel/analytics": "^1.6.1",
    "devicon": "^2.17.0",
    "express": "^5.2.1",
    "fontawesome": "^5.6.3",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.4",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.3",
    "angular-cli-ghpages": "^3.0.2",
    "angular-eslint": "21.2.0",
    "eslint": "^9.0.0",
    "jsdom": "^28.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.55.0",
    "vitest": "^4.0.18"
  }
}
